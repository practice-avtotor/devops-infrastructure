# ============================================
# Переменные окружения для BOM System
# ============================================

# Redis (брокер Celery)
REDIS_URL=redis://redis:6379/0

# SQLite
SQLITE_DB_PATH=/app/data/tasks.db

# Хранилище файлов
STORAGE_PATH=/app/storage

# Backend порт
BACKEND_PORT=8000

# Frontend порт
FRONTEND_PORT=5173
